{
  "projectType": "electron",
  "maxReworks": 2,
  "timeouts": {
    "commandMs": 120000,
    "captureMs": 45000,
    "codexMs": 180000,
    "opencodeMs": 300000
  },
  "commands": {
    "typecheck": "cmd /c npm run typecheck",
    "test": "cmd /c npm test",
    "build": "cmd /c npm run build",
    "start": "cmd /c node tools/agent-runner/electron-preview.mjs {port}"
  },
  "capture": {
    "enabled": true,
    "port": 9229,
    "startupDelayMs": 5000,
    "screenshotName": "main-window.png"
  },
  "codex": {
    "command": "codex",
    "planningSchema": "tools/agent-runner/schemas/task.schema.json",
    "verdictSchema": "tools/agent-runner/schemas/verdict.schema.json"
  },
  "opencode": {
    "hostname": "127.0.0.1",
    "port": 4096,
    "timeout": 15000,
    "config": {},
    "model": null
  }
}
